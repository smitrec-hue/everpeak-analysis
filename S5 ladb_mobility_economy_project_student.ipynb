   "source": [
    "\n",
    "# Crear boxplot para observar el comportamiento de los minutos de congestion JamsDelay\n",
    "# crea tu gráfico\n",
    "plt.figure(figsize=(8, 5))\n",
    "sns.boxplot(\n",
    "    data=merged,\n",
    "    y='jams_delay',\n",
    "    showmeans=True\n",
    ")\n",
    "# obtener promedio para mostrarlo en título\n",
    "mean_value = merged['jams_delay'].mean()\n",
    "plt.title(f'Boxplot de JamsDelay (2024)\\nPromedio: {mean_value:.2f}')\n",
    "plt.ylabel('Minutos de congestión')\n",
    "plt.show()\n",
    "\n",
    "# Se observa en los resultados que existe una distribución asimétrica al estar la mediana y media muy diferentes.\n",
    "# Existen además algunos valores muy altos comparados con la media y la mediana, lo cual puede ser el reflejp de las grandes ciudades."
   ]
